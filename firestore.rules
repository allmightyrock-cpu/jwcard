// 전자구역카드 시스템 — Firestore 보안 규칙
//
// [적용 방법]
// Firebase 콘솔 → Firestore Database → 규칙 탭 → 아래 내용으로 교체 후 [게시]
//
// [원리]
// 앱은 로드 시 자동으로 Firebase 익명 인증(signInAnonymously)을 수행합니다.
// request.auth != null 조건은 앱을 통해 접속한 사용자만 허용하고,
// 외부에서 API키만으로 직접 접근하는 것을 차단합니다.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
